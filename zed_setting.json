// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "git": {
    "hunk_style": "staged_hollow",
    "inline_blame": {
      "show_commit_summary": true,
      "padding": 7,
    },
    "gutter_debounce": 1,
    "git_gutter": "tracked_files",
    "disable_git": true,
  },
  "minimum_contrast_for_highlights": 50.0,
  "unnecessary_code_fade": 0.5,
  "cursor_shape": "block",
  "multi_cursor_modifier": "cmd_or_ctrl",
  "buffer_line_height": {
    "custom": 1.8,
  },
  "agent_servers": {
    "claude": {
      "favorite_config_option_values": {
        "mode": ["plan", "acceptEdits"],
      },
    },
    "codex": {
      "default_model": "gpt-5.2-codex/high",
      "favorite_models": ["gpt-5.2-codex/high"],
      "default_config_options": {},
      "favorite_config_option_values": {},
    },
  },
  "icon_theme": "Material Icon Theme",
  "agent_ui_font_size": 21.0,
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "base_keymap": "VSCode",
  "minimap": {
    "show": "never",
  },
  // "autosave": "on_focus_change",
  "buffer_font_fallbacks": ["Victor Mono", "Monaspace Krypton"],
  "auto_indent_on_paste": true,
  "ui_font_size": 23.0,
  "buffer_font_size": 17.0,

  "buffer_font_family": "Fira Code",
  "buffer_font_features": {
    "calt": true,
  },

  ////////================================ New
  "inlay_hints": {
    "show_other_hints": false,
    "show_parameter_hints": false,
    "show_type_hints": false,
    "show_value_hints": true,
  },
  // "ui_font_size": 16,
  // "buffer_font_size": null,

  // "buffer_font_features": {
  //   "calt": false, // ligatures
  // },
  "lsp_document_colors": "border",
  "wrap_guides": [79],
  "show_edit_predictions": false,

  // Theme & Colors
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Tokyo Night Storm",
  },
  "experimental.theme_overrides": {
    "background.appearance": "transparent",
    "syntax": {
      "keyword": { "color": "#9D70FF" },
      "function": { "color": "#BCBEC4" },
    },
  },

  // =========================
  // Editor Behavior
  // =========================
  "autosave": {
    "after_delay": { "milliseconds": 500 },
  },
  "format_on_save": "on",
  "restore_on_startup": "last_session",
  "show_completions_on_input": true,

  // =========================
  // AI & Assistant Features
  // =========================
  "agent": {
    "play_sound_when_agent_done": true,
    "inline_assistant_model": {
      "provider": "zed.dev",
      "model": "claude-sonnet-4-thinking",
    },
    "default_model": {
      "provider": "zed.dev",
      "model": "claude-sonnet-4",
    },
  },
  "edit_predictions": {
    "mode": "subtle",
    "enabled_in_text_threads": false,
    "copilot": {
      "proxy": null,
      "proxy_no_verify": null,
    },
  },
  "toolbar": {
    "breadcrumbs": false,
    "quick_actions": false,
    "selections_menu": true,
  },
  "project_panel": {
    "entry_spacing": "standard",
  },
  "tabs": {
    "file_icons": true,
  },
  "current_line_highlight": "none",
}
