{
  "permissions": {
    "allow": [
      "Bash(stow -d /Users/mehr/dev/dotfiles -t ~ home)",
      "Bash(stow --simulate -d . -t ~ home)",
      "Bash(stow --simulate -v -d /Users/mehr/dev/dotfiles -t ~ home)",
      "Bash(stow --simulate -v 2 -d /Users/mehr/dev/dotfiles -t /tmp/stow_test home)",
      "Bash(git add:*)",
      "Bash(git rm:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(chmod +x /Users/mehr/dev/dotfiles/brew/dump.sh /Users/mehr/dev/dotfiles/brew/install.sh)",
      "Bash(sh /Users/mehr/dev/dotfiles/brew/dump.sh)",
      "Bash(rm /Users/mehr/dev/dotfiles/.gitconfig)",
      "Bash(stow -d ~/dev/dotfiles -t ~ home)",
      "WebFetch(domain:docs.anthropic.com)",
      "Bash(stow --help)",
      "Bash(stow:*)",
      "mcp__plugin_claude-mem_mcp-search__search"
    ],
    "defaultMode": "plan"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/block-dangerous-git.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "claude-mem@thedotmack": true,
    "security-guidance@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "hookify@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "thedotmack": {
      "source": {
        "source": "github",
        "repo": "thedotmack/claude-mem"
      }
    }
  },
  "skipDangerousModePermissionPrompt": true
}
